# Copy this file to `.env` locally and fill with non-production values only.
# Never commit `.env` files. Use GitHub Secrets/Azure Key Vault for real secrets.

# Azure deployment context
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_LOCATION=westeurope
AZURE_RESOURCE_GROUP=rg-saas-dev-platform

# GitHub OIDC app/service principal values used by workflow setup
AZURE_CLIENT_ID=

# IaC parameters
IAC_ENVIRONMENT=dev
IAC_PROJECT_PREFIX=saas
IAC_ENABLE_PUBLIC_WEB_INGRESS=false
# Comma-separated CIDRs if public ingress is enabled, example:
# IAC_ALLOWED_INGRESS_CIDRS=203.0.113.10/32,198.51.100.0/24
IAC_ALLOWED_INGRESS_CIDRS=
